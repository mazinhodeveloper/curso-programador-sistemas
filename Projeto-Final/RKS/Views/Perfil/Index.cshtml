@model List<API.Data.Models.PERFIL>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">PERFIL - Permissões</h2>
    <a href="/perfil/create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Novo
    </a>
</div>

<div class="card card-custom p-3">

    <div class="table-responsive">
        <table class="table table-hover align-middle">

            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Tipo</th>
                    <th>Descrição</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="badge bg-secondary">@item.idPerfil</span>
                        </td>

                        <td>
                            <strong>@item.tipo</strong>
                        </td>

                        <td>
                            @item.descricao
                        </td>

                        <td class="text-end">

                            <a href="/perfil/details/@item.idPerfil"
                               class="btn btn-sm btn-outline-dark me-2">
                                <i class="bi bi-eye"></i>
                            </a>

                            <a href="/perfil/edit/@item.idPerfil"
                               class="btn btn-sm btn-outline-primary me-2">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <a href="/perfil/delete/@item.idPerfil"
                               class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>

                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

</div>

<br />
<a href="/" class="btn btn-secondary">
    <i class="bi bi-arrow-left-short"></i> Voltar para Home
</a>
