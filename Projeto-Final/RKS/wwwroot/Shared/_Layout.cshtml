<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>RKS - Transporte Escolar</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary-custom">
        <div class="container-fluid">
            <img src="~/images/logo.png" width="50" class="me-2" />
            <span class="navbar-brand fw-bold">RKS</span>

            <div class="ms-auto text-white">
                <i class="bi bi-person-circle"></i> Admin
                <a class="btn btn-warning btn-sm ms-3">Logout</a>
            </div>
        </div>
    </nav>

    <div class="d-flex">

        <!-- SIDEBAR -->
        <aside class="sidebar p-3">

            <h6 class="text-white">MENU</h6>

            <ul class="nav flex-column">

                <li class="nav-item">
                    <a class="nav-link" href="/">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Aluno">
                        <i class="bi bi-people"></i> Alunos
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Responsavel">
                        <i class="bi bi-person"></i> Responsáveis
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Chamada">
                        <i class="bi bi-check2-square"></i> Lista de Chamada
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Relatorio">
                        <i class="bi bi-file-earmark-text"></i> Relatórios
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/Pagamento">
                        <i class="bi bi-cash"></i> Pagamentos
                    </a>
                </li>

            </ul>
        </aside>

        <!-- MAIN -->
        <main class="content p-4 w-100">
            @RenderBody()
        </main>

    </div>

    <!-- FOOTER -->
    <footer class="text-center p-2 bg-dark text-white">
        © 2026 - RKS Transporte Escolar
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>